# Auth Service Environment Variables

# Server Configuration
PORT=8001
ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=meditrack_auth

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=24h

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:8000

# Service URLs
PATIENT_SERVICE_URL=http://localhost:8002
DOCTOR_SERVICE_URL=http://localhost:8003
APPOINTMENT_SERVICE_URL=http://localhost:8004
PRESCRIPTION_SERVICE_URL=http://localhost:8005
PHARMACY_SERVICE_URL=http://localhost:8006
ANALYTICS_SERVICE_URL=http://localhost:8007
